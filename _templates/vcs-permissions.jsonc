      "git show-branch *": "deny",
      "git grep *": "deny",
      "git branch": "deny",
      "git branch -a": "deny",
      "git branch -r": "deny",
      "git branch -v": "deny",
      "git branch --list *": "deny",
      "git branch --contains *": "deny",
      "git branch --merged *": "deny",
      "git branch --no-merged *": "deny",
      "git tag": "deny",
      "git tag -l *": "deny",
      "git tag -v *": "deny",
      "git tag --list *": "deny",
      "git tag --contains *": "deny",
