// =============================================================================
// Permission Template: VCS Permissions (Mixin)
// =============================================================================
//
// Category: vcs-permissions
// Description: Shared VCS and MCP CLI permissions inherited by all complex templates
//
// Purpose:
//   This is a MIXIN template — it is not extended by agents directly.
//   Instead, other templates (backend-api, frontend-ui, lang-rust, etc.)
//   declare "$extends": ["vcs-permissions"] to inherit these entries.
//
//   Contains git, Jujutsu (jj), RTK proxy git, and MCP CLI permissions
//   that are identical across all complex category templates.
//
// Usage:
//   To use this mixin, add "$extends": ["vcs-permissions"] to a template.
//   The inheriting template's own baseline entries take priority over
//   entries from this mixin.
//
// =============================================================================
{
  "$schema": "https://raw.githubusercontent.com/nmindz/agency/master/schemas/template.json",
  "$version": "2.0.0",
  "$doc": {
    "baseline_rationale": "Comprehensive VCS permission set covering git (read-only, plumbing, staging, committing, branching, switching, reset, stash, merge/rebase, tags, config, remote, destructive, submodule, worktree, init, patch, bisect, maintenance, notes, reflog, plumbing mutation, external), Jujutsu (jj) operations, RTK-proxied git commands, and MCP CLI access",
    "security_note": "All VCS operations denied by default. Agents override specific commands to 'allow' or 'ask' via their agent override files."
  },
  "category": "vcs-permissions",
  "description": "Shared VCS and MCP CLI permissions inherited by all complex templates",
  "purpose": "Mixin template providing git, Jujutsu (jj), RTK proxy git, and MCP CLI permission entries. Not extended by agents directly — used by other templates via $extends to eliminate duplication of ~500 VCS permission entries across 10 category templates.",
  "baseline": {
    "permission": {
      // --- Git: Read-Only ---
      "git status": "deny",
      "git status *": "deny",
      "git log": "deny",
      "git log *": "deny",
