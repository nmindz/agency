      "git remote -v": "deny",
      "git remote show *": "deny",
      "git remote get-url *": "deny",
      "git config --get *": "deny",
      "git config --get-all *": "deny",
      "git config --list": "deny",
      "git config --list *": "deny",
      "git config -l": "deny",
      "git version": "deny",
      "git --version": "deny",
      "git help": "deny",
      "git help *": "deny",
      "git reflog": "deny",
      "git reflog show *": "deny",
      "git cherry *": "deny",
      "git fsck": "deny",
      "git fsck *": "deny",
